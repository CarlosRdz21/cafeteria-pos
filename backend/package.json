{
  "name": "cafeteria-pos-backend",
  "version": "1.0.0",
  "description": "Backend para sistema POS",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "test": "echo \"No tests yet\"",
    "db:test:connection": "ts-node src/scripts/test-db-connection.ts",
    "api:smoke": "node scripts/smoke-api.js",
    "prisma:mysql:generate": "prisma generate --schema prisma/schema.mysql.prisma",
    "prisma:mysql:migrate": "prisma migrate dev --schema prisma/schema.mysql.prisma",
    "prisma:mysql:push": "prisma db push --schema prisma/schema.mysql.prisma",
    "import:clean-snapshot": "ts-node scripts/import-clean-snapshot.ts"
  },
  "keywords": [
    "pos",
    "socket.io",
    "real-time"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.15.2",
    "pg": "^8.17.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "@types/socket.io": "^3.0.1",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.1",
    "ts-node": "^10.9.2"
  }
}
